rules_version = '2';

// قواعد أمان Cloud Firestore لتطبيق زاد.
// المبدأ: كل مستخدم يقرأ/يكتب سجل يومياته الغذائية الخاصة فقط، ولا أحد غيره.
// المصادقة مجهولة (anonymous auth) — الهوية الوحيدة هي uid الجلسة.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // وثيقة المستخدم نفسها — غير مستخدمة حالياً بالتطبيق، محجوزة لصاحبها فقط
    // احتياطًا لأي حقل يُضاف لاحقًا (اسم، تفضيلات، إلخ).
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // اليوميات: مجلد لكل يوم (dayKey بصيغة YYYY-MM-DD).
      match /diary/{dayKey} {
        allow read, write: if isOwner(userId);

        // الوجبات المسجلة داخل كل يوم — نفس صاحب الحساب فقط.
        match /meals/{mealId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // الافتراضي: منع كل ما سوى ذلك صراحةً.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
